# ─────────────────────────────────────────────────────────
# MEDEL Tracker — environment variables
# Copy this file: cp .env.example .env
# Fill in your values below, then deploy.
# ─────────────────────────────────────────────────────────

# Supabase PostgreSQL connection string
# From: Supabase → Settings → Database → URI (port 5432, NOT 6543)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Long random secret used to sign login tokens
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-secret

# Shared password your team uses to log in
APP_PASSWORD=MEDEL@VSB

# Port the server listens on (Render uses 10000, local use 5000)
PORT=5000

# Set to "production" when deploying
NODE_ENV=development

# URL base path — leave as "/" for root deployments
BASE_PATH=/
