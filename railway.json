{
  "$schema": "https://schema.railway.app/railway-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm --filter @workspace/api-server run build"
  },
  "deploy": {
    "startCommand": "node --enable-source-maps artifacts/api-server/dist/index.mjs",
    "healthcheckPath": "/api/healthz"
  }
}